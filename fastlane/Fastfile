default_platform(:ios)

platform :ios do

  # App Store Connect API key auth (no 2FA prompts)
  def load_asc_api_key
    app_store_connect_api_key(
      key_id: "4YK92UN5LD",
      issuer_id: "c075787d-8402-4d6e-9437-d30375dff8f7",
      key_filepath: "fastlane/AuthKey_4YK92UN5LD.p8",
      duration: 1200,
      in_house: false
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = load_asc_api_key

    # Install pods
    cocoapods(podfile: "ios/Podfile")

    # Bump build number to latest TestFlight + 1
    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.kumaran.wezume"
      ) + 1,
      xcodeproj: "ios/vprofile.xcodeproj"
    )

    # Build
    build_app(
      workspace: "ios/vprofile.xcworkspace",
      scheme: "vprofile",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      app_identifier: "com.kumaran.wezume",
      skip_waiting_for_build_processing: true
    )
  end

  desc "Submit to App Store"
  lane :release do
    api_key = load_asc_api_key

    cocoapods(podfile: "ios/Podfile")

    increment_build_number(
      build_number: latest_testflight_build_number(
        api_key: api_key,
        app_identifier: "com.kumaran.wezume"
      ) + 1,
      xcodeproj: "ios/vprofile.xcodeproj"
    )

    build_app(
      workspace: "ios/vprofile.xcworkspace",
      scheme: "vprofile",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_app_store(
      api_key: api_key,
      app_identifier: "com.kumaran.wezume",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false
    )
  end

end
